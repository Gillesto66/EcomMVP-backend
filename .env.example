# Auteur : Gilles - Projet : AGC Space - Module : Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copier ce fichier : cp .env.example .env
# Puis remplir chaque valeur avant de lancer le projet.
# NE JAMAIS commiter le fichier .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
# Générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-50-char-secret-key-here

DEBUG=True
# En production : DEBUG=False
# Liste des domaines autorisés (séparés par virgule)
ALLOWED_HOSTS=localhost,127.0.0.1
# En production : ALLOWED_HOSTS=votre-domaine.com,www.votre-domaine.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Installer PostgreSQL : https://www.postgresql.org/download/
# Créer la base : createdb agc_space
DB_NAME=agc_space
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432
# Connexions persistantes (secondes) — 0 pour désactiver
DB_CONN_MAX_AGE=60

# ── Redis ─────────────────────────────────────────────────────────────────────
# Installer Redis : https://redis.io/docs/getting-started/
# Windows : https://github.com/microsoftarchive/redis/releases
# Ou via Docker : docker run -d -p 6379:6379 redis:alpine
REDIS_URL=redis://localhost:6379/0

# TTL du cache (secondes)
CACHE_TTL_PAGE_RENDER=300    # 5 min — pages de vente
CACHE_TTL_THEME=3600         # 1h   — thèmes CSS
CACHE_TTL_PRODUCT=120        # 2min — données produit

# ── CORS (frontend React/Next.js) ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# En production : CORS_ALLOWED_ORIGINS=https://votre-domaine.com

# ── HMAC (sécurité liens d'affiliation) ───────────────────────────────────────
# Clé dédiée pour les signatures HMAC — différente de SECRET_KEY
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
HMAC_SECRET_KEY=your-hmac-secret-key-here

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ── Rate limiting ─────────────────────────────────────────────────────────────
THROTTLE_ANON=100/hour
THROTTLE_USER=1000/hour
THROTTLE_LOGIN=10/minute    # Anti brute-force sur /auth/login/

# ── Pagination ────────────────────────────────────────────────────────────────
PAGE_SIZE=20

# ── Logs ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
# En production : LOG_LEVEL=INFO
